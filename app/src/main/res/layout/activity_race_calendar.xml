<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_back"
            android:layout_gravity="top|start"
            android:layout_marginTop="40dp"
            android:layout_marginStart="20dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/btn_menu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="menu"
            android:textColor="@color/text_primary"
            android:textSize="10sp"
            android:fontFamily="@font/formula1_wide"
            android:layout_gravity="top|end"
            android:layout_marginTop="40dp"
            android:layout_marginEnd="20dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2026 Season"
            android:textColor="@color/text_primary"
            android:textSize="36sp"
            android:fontFamily="@font/formula1_wide"
            android:layout_gravity="start"
            android:layout_marginTop="100dp"
            android:layout_marginStart="20dp" />

    </FrameLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <!-- previous -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="previous"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="@font/formula1_regular"
                android:layout_marginBottom="12dp" />

            <include layout="@layout/item_race"
                android:id="@+id/race_australia" />

            <!-- current -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="current"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="@font/formula1_regular"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp" />

            <include layout="@layout/item_race"
                android:id="@+id/race_china" />

            <!-- upcoming -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="upcoming"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="@font/formula1_regular"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp" />

            <include layout="@layout/item_race"
                android:id="@+id/race_japan" />

            <include layout="@layout/item_race"
                android:id="@+id/race_bahrain"
                android:layout_marginTop="12dp" />

            <include layout="@layout/item_race"
                android:id="@+id/race_saudi"
                android:layout_marginTop="12dp" />

            <include layout="@layout/item_race"
                android:id="@+id/race_miami"
                android:layout_marginTop="12dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>