<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_race_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_country"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:fontFamily="@font/formula1_wide" />

        <TextView
            android:id="@+id/tv_round"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:fontFamily="@font/formula1_wide" />

    </LinearLayout>

    <TextView
        android:id="@+id/tv_city"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/accent_red"
        android:textSize="24sp"
        android:fontFamily="@font/valen_valentine_script"
        android:layout_marginTop="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <!-- my prediction колонка -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="my prediction"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="@font/formula1_regular"
                android:layout_marginBottom="20dp" />

            <LinearLayout
                android:id="@+id/container_p1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="20dp"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="@font/formula1_regular" />

                <TextView
                    android:id="@+id/tv_p1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="tap to pick"
                    android:textColor="@color/text_disabled"
                    android:textSize="12sp"
                    android:fontFamily="@font/formula1_regular"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btn_clear_p1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✕"
                    android:textColor="@color/text_disabled"
                    android:textSize="10sp"
                    android:visibility="gone"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/container_p2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="20dp"
                    android:layout_height="wrap_content"
                    android:text="2"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="@font/formula1_regular" />

                <TextView
                    android:id="@+id/tv_p2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="tap to pick"
                    android:textColor="@color/text_disabled"
                    android:textSize="12sp"
                    android:fontFamily="@font/formula1_regular"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btn_clear_p2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✕"
                    android:textColor="@color/text_disabled"
                    android:textSize="10sp"
                    android:visibility="gone"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/container_p3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="20dp"
                    android:layout_height="wrap_content"
                    android:text="3"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="@font/formula1_regular" />

                <TextView
                    android:id="@+id/tv_p3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="tap to pick"
                    android:textColor="@color/text_disabled"
                    android:textSize="12sp"
                    android:fontFamily="@font/formula1_regular"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btn_clear_p3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✕"
                    android:textColor="@color/text_disabled"
                    android:textSize="10sp"
                    android:visibility="gone"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>

        <!-- вертикальная черта -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/text_disabled"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp" />

        <!-- reality колонка -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="reality"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="@font/formula1_regular"
                android:layout_marginBottom="20dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="20dp"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="@font/formula1_regular" />

                <TextView
                    android:id="@+id/tv_r1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="..."
                    android:textColor="@color/text_disabled"
                    android:textSize="12sp"
                    android:fontFamily="@font/formula1_regular" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="20dp"
                    android:layout_height="wrap_content"
                    android:text="2"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="@font/formula1_regular" />

                <TextView
                    android:id="@+id/tv_r2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="..."
                    android:textColor="@color/text_disabled"
                    android:textSize="12sp"
                    android:fontFamily="@font/formula1_regular" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="20dp"
                    android:layout_height="wrap_content"
                    android:text="3"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="@font/formula1_regular" />

                <TextView
                    android:id="@+id/tv_r3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="..."
                    android:textColor="@color/text_disabled"
                    android:textSize="12sp"
                    android:fontFamily="@font/formula1_regular" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>